{
  "name": "tradingview-mcp",
  "version": "0.1.0",
  "description": "MCP server that lets AI analyze the TradingView desktop app via Chrome DevTools Protocol",
  "type": "module",
  "bin": {
    "tradingview-mcp": "build/index.js"
  },
  "main": "build/index.js",
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "node build/index.js",
    "evaluate": "node build/evaluate.js",
    "walk-forward": "node build/walkForwardCli.js",
    "pretest": "npm run build",
    "test": "node --test test/unit/*.test.mjs",
    "test:integration": "node test/smoke.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fast-xml-parser": "^5.10.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.3"
  }
}
